# App
APP_NAME=Sentinel AI Backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
JWT_SECRET_KEY=change-me-in-production-use-at-least-32-random-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5433/sentinel_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO

# Continuum (the only AI runtime in this project - see app/continuum/).
# These are the Continuum SDK's OWN env vars (no CONTINUUM_ prefix - that's
# its top-level package name, not a namespacing convention it follows).
# Sentinel's own code never reads these directly or calls a model SDK itself.
DEFAULT_LLM_MODEL=gemini/gemini-2.5-flash
# Preferred for this hackathon: route everything through the shared Smart
# Gateway instead of per-provider keys. Ask a teammate for the gateway key.
SMART_GATEWAY_URL=https://continuum.shyftops.io/v1
# SMART_GATEWAY_API_KEY=
# Any literal model string above is discarded once the gateway is in use -
# the gateway only accepts a quality tier (strict=cheap, modest=mid,
# quality=quality) and picks the actual model itself, server-side.
# Empirically tested (see the diagnostic notes in CLAUDE.md): "quality" tier
# routes structured PR reviews to slower models (Opus-class) that can need
# more than the gateway's own ~180s reverse-proxy ceiling to finish - the
# request gets killed with a 504 before the model even returns. "modest"
# routes to faster models that reliably finish within that ceiling, at the
# cost of some review depth. Reliability over max quality for a live demo.
SMART_GATEWAY_DEFAULT_MODE=modest
# SDK default is 60s per attempt x 3 retries (~180s to fail) - too tight for
# a full structured PR review, so both are widened here.
LLM_REQUEST_TIMEOUT=120
LLM_MAX_RETRIES=2
# Sentinel's PR review is single-shot and stateless - no memory/session/
# tracing infra needed. app/continuum/client.py already disables these via
# ContainerConfig regardless of these flags, but set them for consistency
# if you use the Continuum SDK directly (e.g. in the playground).
MEMORY_ENABLED=false
SESSION_ENABLED=false
LANGFUSE_ENABLED=false
TEMPORAL_ENABLED=false

# AI fallback - Sentinel's OWN setting (app/config/settings.py), not a
# Continuum SDK var. If Continuum/the Smart Gateway doesn't respond within
# this many seconds, app/continuum/fallback.py calls OpenAI directly, then
# Anthropic, each bounded by its own 20s timeout. Purely additive: if neither
# key below is set, behavior is unchanged (the original Continuum error
# surfaces as before) - this only activates once you add a real key.
CONTINUUM_FALLBACK_TIMEOUT_SECONDS=30
# OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# Slack incident notifications (app/integrations/slack/). Create an Incoming
# Webhook at https://api.slack.com/apps -> your app -> Incoming Webhooks, and
# paste the URL below. Purely additive: if unset, IncidentService just skips
# the notification, same as before this existed.
# SLACK_WEBHOOK_URL=

# Health monitor (app/services/health_monitor.py) - polls all local Docker
# containers on a timer and auto-opens+analyzes an incident (which fires the
# Slack alert above) for anything unhealthy/exited, with no human action
# needed. Set to false to disable entirely (e.g. on a shared Docker host).
HEALTH_MONITOR_ENABLED=true
HEALTH_MONITOR_INTERVAL_SECONDS=20
